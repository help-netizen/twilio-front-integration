# Front App Credentials
FRONT_APP_UID=your_app_uid_here
FRONT_APP_SECRET=your_app_secret_here

# Twilio Credentials (for testing/development)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/twilio_front_integration

# Webhook Configuration
CALLBACK_HOSTNAME=https://your-server.com
WEBHOOK_SECRET=random_secret_for_signature_verification

# Logging
LOG_LEVEL=info

# Realtime Transcription (Twilio Media Streams + AssemblyAI)
FEATURE_REALTIME_TRANSCRIPTION=false
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# SoftPhone (Twilio Voice JS SDK — WebRTC)
TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_SECRET=your_api_secret
SOFTPHONE_CALLER_ID=+16175006181
SOFTPHONE_DEFAULT_IDENTITY=user_1

# Web Push Notifications (VAPID)
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:admin@example.com

# VAPI AI Assistant Tools (inbound lead qualification)
# Shared secret between VAPI and our /api/vapi-tools endpoint
# Must match the secret configured on the VAPI assistant tools
VAPI_TOOLS_SECRET=your_random_secret_here
# Google Maps Geocoding — dedicated server-side key for the backend
# validateAddress tool handler. Restrict to Geocoding API + server IP.
# (Separate from the frontend VITE_GOOGLE_MAPS_API_KEY, which is referrer-restricted.)
# Falls back to VITE_GOOGLE_MAPS_API_KEY if unset.
GOOGLE_GEOCODING_KEY=your-server-geocoding-key-here

# F018 Stripe Payments (tenant customer payments) — separate from platform billing
STRIPE_SECRET_KEY=sk_test_xxx          # platform key (reused for Connect; test mode = sk_test_)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_xxx # signing secret for POST /api/stripe-payments/webhook

# SLOT-ENGINE-001 Phase 2 — standalone slot-recommendation engine (Albusto proxies to it).
# Unset → slot recommendations degrade to empty (engine_status='unavailable').
SLOT_ENGINE_URL=http://localhost:4500
